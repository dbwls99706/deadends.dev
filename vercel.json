{
  "version": 2,
  "builds": [
    {
      "src": "api/mcp.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/mcp/server-card.json",
      "destination": "/api/mcp.py"
    },
    {
      "source": "/api/mcp",
      "destination": "/api/mcp.py"
    },
    {
      "source": "/api/mcp/",
      "destination": "/api/mcp.py"
    },
    {
      "source": "/api",
      "destination": "/api/mcp.py"
    },
    {
      "source": "/api/",
      "destination": "/api/mcp.py"
    },
    {
      "source": "/mcp",
      "destination": "/api/mcp.py"
    },
    {
      "source": "/mcp/",
      "destination": "/api/mcp.py"
    }
  ],
  "headers": [
    {
      "source": "/api/v1/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
