{
  "version": 2,
  "trailingSlash": true,
  "cleanUrls": true,
  "builds": [
    {
      "src": "api/mcp.py",
      "use": "@vercel/python"
    }
  ],
  "redirects": [
    {
      "source": "/python/overflowerror/:path*",
      "destination": "/python/overflowerror-int-too-large/:path*",
      "statusCode": 301
    },
    {
      "source": "/node/enospc-watchers/:path*",
      "destination": "/node/enospc-system-limit-watchers/:path*",
      "statusCode": 301
    },
    {
      "source": "/rust/e0507-cannot-move-out-of-borrowed/:path*",
      "destination": "/rust/e0507-move-out-of-borrow/:path*",
      "statusCode": 301
    },
    {
      "source": "/node/err-stream-premature-close/:path*",
      "destination": "/node/node-stream-premature-close/:path*",
      "statusCode": 301
    },
    {
      "source": "/node/err-unknown-file-extension-ts/:path*",
      "destination": "/node/err-unknown-file-extension/:path*",
      "statusCode": 301
    },
    {
      "source": "/node/syntax-error-unexpected-token-import/:path*",
      "destination": "/node/ts-node-syntax-error/:path*",
      "statusCode": 301
    },
    {
      "source": "/rust/e0502-borrow-conflict/:path*",
      "destination": "/rust/e0502-mutable-immutable-borrow/:path*",
      "statusCode": 301
    },
    {
      "source": "/node/abort-error/:path*",
      "destination": "/node/node-fetch-abort/:path*",
      "statusCode": 301
    },
    {
      "source": "/node/digital-envelope-unsupported/:path*",
      "destination": "/node/node-crypto-unsupported/:path*",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/mcp/server-card.json",
      "destination": "/api/mcp.py"
    },
    {
      "source": "/api/mcp",
      "destination": "/api/mcp.py"
    },
    {
      "source": "/api/mcp/",
      "destination": "/api/mcp.py"
    },
    {
      "source": "/api",
      "destination": "/api/mcp.py"
    },
    {
      "source": "/api/",
      "destination": "/api/mcp.py"
    },
    {
      "source": "/mcp",
      "destination": "/api/mcp.py"
    },
    {
      "source": "/mcp/",
      "destination": "/api/mcp.py"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
        }
      ]
    },
    {
      "source": "/api/v1/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        }
      ]
    },
    {
      "source": "/feed.xml",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    }
  ]
}
