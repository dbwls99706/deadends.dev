{
  "version": 2,
  "trailingSlash": true,
  "builds": [
    {
      "src": "api/mcp.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/mcp",
      "destination": "/api/mcp.py"
    },
    {
      "source": "/mcp",
      "destination": "/api/mcp.py"
    }
  ]
}
